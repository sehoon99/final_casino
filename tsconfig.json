{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["packages/**/*.ts", "config/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
